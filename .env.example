# Secret token for Bearer auth. Replace the value with a long random string.
# Do NOT use change-me, default, 12345 or other simple words.
# Keep this token private: never share it in screenshots or chat messages.
# Tip: generate one with: py -3.13 -c "import secrets; print(secrets.token_urlsafe(48))"
AGENT_TOKEN=replace-this-with-a-long-random-secret-token
AGENT_HOST=127.0.0.1
AGENT_PORT=8787
WORKSPACE_ROOTS=C:\SecondLane
SSH_ALLOWED_HOSTS_JSON=[]
SSH_ALLOWED_CIDRS_JSON=[]
ENABLED_PROVIDER_MANIFESTS=C:\SecondLane\app\providers
STATE_DB_PATH=C:\SecondLane\data\agent.db
MAX_OUTPUT_CHARS=50000
MAX_FILE_BYTES=1048576
DEFAULT_TIMEOUT_SEC=30
# Tunnel: ngrok free static domain (create at dashboard.ngrok.com -> Domains)
# The installer can install/find ngrok and save the authtoken for you.
NGROK_DOMAIN=your-domain.ngrok-free.dev
# Optional: full path to ngrok.exe if Windows cannot find it automatically.
# NGROK_PATH=C:\Users\YourName\Downloads\ngrok.exe
SSH_KNOWN_HOSTS_PATH=%USERPROFILE%\.ssh\known_hosts
GUI_ALLOWED_APPS_JSON=["chrome.exe","explorer.exe","notepad.exe","powershell.exe","Code.exe"]
# Optional provider tokens. The core agent does not require them.
# PROVIDER_GITHUB_TOKEN=
# PROVIDER_VERCEL_TOKEN=
# PROVIDER_RAILWAY_TOKEN=
